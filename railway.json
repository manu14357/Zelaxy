{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd apps/zelaxy && bun install",
    "watchPatterns": [
      "apps/zelaxy/socket-server/**",
      "apps/zelaxy/lib/**",
      "apps/zelaxy/db/**",
      "apps/zelaxy/package.json"
    ]
  },
  "deploy": {
    "startCommand": "cd apps/zelaxy && bun run start:sockets",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
