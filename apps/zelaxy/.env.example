# =============================================================================
# Zelaxy Environment Variables Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values
# Required variables are marked with [REQUIRED]
# =============================================================================

# -----------------------------------------------------------------------------
# Core Database & Authentication [REQUIRED]
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/zelaxy"
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="your-secret-key-min-32-characters-long"
ENCRYPTION_KEY="your-64-character-hex-string-for-aes-256-encryption-key"
INTERNAL_API_SECRET="your-internal-api-secret-min-32-chars"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Disable new user registration
# DISABLE_REGISTRATION=false

# Optional: Restrict login to specific emails (comma-separated)
# ALLOWED_LOGIN_EMAILS="admin@example.com,user@example.com"

# Optional: Restrict login to specific email domains (comma-separated)
# ALLOWED_LOGIN_DOMAINS="example.com,company.com"

# -----------------------------------------------------------------------------
# AI/LLM Provider API Keys
# -----------------------------------------------------------------------------
# Configure at least one LLM provider for Agie AI Copilot to work

# OpenAI - For GPT-4, GPT-4o models
# Single key or use multiple for load balancing
OPENAI_API_KEY=""
# OPENAI_API_KEY_1=""
# OPENAI_API_KEY_2=""
# OPENAI_API_KEY_3=""

# Anthropic - For Claude models (default provider for Agie)
# Single key or use multiple for load balancing
ANTHROPIC_API_KEY=""
# ANTHROPIC_API_KEY_1=""
# ANTHROPIC_API_KEY_2=""
# ANTHROPIC_API_KEY_3=""

# Google AI - For Gemini models
GOOGLE_API_KEY=""

# Groq - Fast inference, free tier available (recommended for open-source models)
GROQ_API_KEY=""

# DeepSeek - Cost-effective alternative
DEEPSEEK_API_KEY=""

# xAI - For Grok models
XAI_API_KEY=""

# Cerebras - Fast inference
CEREBRAS_API_KEY=""

# NVIDIA NIM - Enterprise GPU inference
NVIDIA_API_KEY=""

# Mistral AI
MISTRAL_API_KEY=""

# -----------------------------------------------------------------------------
# Local/Open-Source LLM Providers
# -----------------------------------------------------------------------------
# Ollama - Run open-source models locally
# Install: https://ollama.ai
OLLAMA_URL="http://localhost:11434"

# LM Studio - Local model inference with OpenAI-compatible API
# Download: https://lmstudio.ai
LM_STUDIO_URL="http://localhost:1234"

# Default embedding model for knowledge base (optional)
# Use 'nomic-embed-text' for Ollama or 'text-embedding-3-small' for OpenAI
DEFAULT_EMBEDDING_MODEL="text-embedding-3-small"

# -----------------------------------------------------------------------------
# Azure OpenAI Configuration (Optional)
# -----------------------------------------------------------------------------
# AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com"
# AZURE_OPENAI_API_VERSION="2024-02-01"

# -----------------------------------------------------------------------------
# Zelaxy Agent API (Optional - enables advanced Copilot features)
# -----------------------------------------------------------------------------
# When not configured, Agie uses direct LLM calls (basic chat only)
# ZELAXY_AGENT_API_URL="http://localhost:8000"
# ZELAXY_AGENT_API_KEY=""

# -----------------------------------------------------------------------------
# Storage Configuration (Optional)
# -----------------------------------------------------------------------------
# Redis - For caching and sessions
# REDIS_URL="redis://localhost:6379"

# AWS S3 Storage
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# S3_BUCKET_NAME=""
# S3_KB_BUCKET_NAME=""
# S3_EXECUTION_FILES_BUCKET_NAME=""

# Azure Blob Storage (alternative to S3)
# AZURE_ACCOUNT_NAME=""
# AZURE_ACCOUNT_KEY=""
# AZURE_STORAGE_CONTAINER_NAME=""

# -----------------------------------------------------------------------------
# Email Configuration (Optional)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=""
# EMAIL_DOMAIN=""

# -----------------------------------------------------------------------------
# OAuth Integrations (Optional)
# -----------------------------------------------------------------------------
# Google (Gmail, Drive, Calendar)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# GitHub
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# Microsoft (Outlook, Teams, OneDrive)
# MICROSOFT_CLIENT_ID=""
# MICROSOFT_CLIENT_SECRET=""

# Slack
# SLACK_CLIENT_ID=""
# SLACK_CLIENT_SECRET=""

# Notion
# NOTION_CLIENT_ID=""
# NOTION_CLIENT_SECRET=""

# Discord
# DISCORD_CLIENT_ID=""
# DISCORD_CLIENT_SECRET=""

# Linear
# LINEAR_CLIENT_ID=""
# LINEAR_CLIENT_SECRET=""

# HubSpot
# HUBSPOT_CLIENT_ID=""
# HUBSPOT_CLIENT_SECRET=""

# Jira
# JIRA_CLIENT_ID=""
# JIRA_CLIENT_SECRET=""

# Confluence  
# CONFLUENCE_CLIENT_ID=""
# CONFLUENCE_CLIENT_SECRET=""

# Airtable
# AIRTABLE_CLIENT_ID=""
# AIRTABLE_CLIENT_SECRET=""

# Supabase
# SUPABASE_CLIENT_ID=""
# SUPABASE_CLIENT_SECRET=""

# X (Twitter)
# X_CLIENT_ID=""
# X_CLIENT_SECRET=""

# Reddit
# REDDIT_CLIENT_ID=""
# REDDIT_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Background Jobs & Scheduling (Optional)
# -----------------------------------------------------------------------------
# TRIGGER_SECRET_KEY=""
# CRON_SECRET=""
# JOB_RETENTION_DAYS="1"

# -----------------------------------------------------------------------------
# Browser Automation (Optional)
# -----------------------------------------------------------------------------
# BROWSERBASE_API_KEY=""
# BROWSERBASE_PROJECT_ID=""

# -----------------------------------------------------------------------------
# Real-time Communication (Optional)
# -----------------------------------------------------------------------------
# SOCKET_SERVER_URL="http://localhost:3001"
# NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
# SOCKET_PORT=3001

# -----------------------------------------------------------------------------
# Payment & Billing (Optional)
# -----------------------------------------------------------------------------
# BILLING_ENABLED=false
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# Text-to-Speech (Optional)
# -----------------------------------------------------------------------------
# ELEVENLABS_API_KEY=""

# -----------------------------------------------------------------------------
# Web Search (Optional)
# -----------------------------------------------------------------------------
# SERPER_API_KEY=""

# -----------------------------------------------------------------------------
# Development & Debugging
# -----------------------------------------------------------------------------
NODE_ENV="development"
NEXT_TELEMETRY_DISABLED="1"

# Cost tracking multipliers (optional)
# COST_MULTIPLIER=1.0
# COPILOT_COST_MULTIPLIER=1.0

# -----------------------------------------------------------------------------
# TOON Encoding (Optional)
# Encode JSON data as TOON (Token-Oriented Object Notation) before sending to
# LLMs. Reduces token usage by ~30-60% for tabular / array-of-objects data.
# Accepted values: "true", "1", "yes" (case-insensitive). Default: off.
# -----------------------------------------------------------------------------
# TOON_ENABLED="false"

# -----------------------------------------------------------------------------
# Documentation (Optional)
# Public URL for the docs site. Defaults to http://docs.localhost:3000 in dev.
# The main app proxies docs subdomain requests to the docs app internally.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_DOCUMENTATION_URL="http://docs.localhost:3000"
# DOCS_INTERNAL_URL="http://docs.localhost:3001"
