{
  "name": "zelaxy-personal",
  "packageManager": "bun@1.2.12",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "start": "cd apps/zelaxy && bun run start:prod",
    "start:prod": "cd apps/zelaxy && bun run start:prod",
    "dev": "turbo run dev",
    "dev:sockets": "cd apps/zelaxy && bun run dev:sockets",
    "dev:full": "concurrently -n \"Zelaxy,Docs\" -c \"cyan,green\" \"cd apps/zelaxy && bun run dev:full\" \"cd apps/docs && bun run dev\"",
    "test": "turbo run test",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format .",
    "lint": "bunx biome check --write --unsafe .",
    "lint:check": "bunx biome check --unsafe .",
    "lint:all": "bun run lint",
    "check": "bunx biome check --files-ignore-unknown=true",
    "prebuild": "echo 'Skipping lint check for now'",
    "type-check": "turbo run type-check"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "dependencies": {
    "@linear/sdk": "40.0.0",
    "@t3-oss/env-nextjs": "0.13.4",
    "@vercel/analytics": "1.5.0",
    "@xyflow/react": "12.10.2",
    "geist": "^1.4.2",
    "react-colorful": "5.6.1",
    "remark-gfm": "4.0.1",
    "socket.io-client": "4.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.0-beta.5",
    "@next/env": "^15.3.2",
    "concurrently": "9.2.1",
    "dotenv-cli": "^8.0.0",
    "simple-icons": "16.13.0",
    "turbo": "2.5.5"
  }
}
