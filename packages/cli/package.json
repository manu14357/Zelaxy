{
  "name": "zelaxy",
  "version": "0.2.0",
  "description": "Zelaxy CLI - Manage workflows, agents, chat, knowledge, tools, and more from your terminal",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "zelaxy": "dist/index.js"
  },
  "scripts": {
    "build": "bun run build:tsc",
    "build:tsc": "tsc",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "zelaxy",
    "ai",
    "workflow",
    "cli",
    "agent",
    "agents",
    "automation",
    "chat",
    "knowledge",
    "tools",
    "mcp"
  ],
  "author": "Zelaxy",
  "license": "MIT",
  "dependencies": {
    "zelaxy-ts-sdk": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "conf": "^12.0.0",
    "dotenv": "^16.3.1",
    "inquirer": "^9.2.12",
    "ora": "^8.0.1",
    "cli-table3": "^0.6.3",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.5.1",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=18"
  },
  "turbo": {
    "tasks": {
      "build": {
        "outputs": [
          "dist/**"
        ]
      }
    }
  }
}
